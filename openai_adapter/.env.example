# Required only if your model files are not under the default hf_models/ layout.
COLA_DIT_PATH=hf_models/cola_dlm/cola_dit
COLA_VAE_PATH=hf_models/cola_dlm/cola_vae
COLA_TOKENIZER_PATH=hf_models/tokenizer.json

# Public model id exposed by /v1/models and accepted by /v1/chat/completions.
COLA_MODEL_NAME=cola-dlm

# Optional bearer token. Leave empty for local testing only.
COLA_API_KEY=change-me

# Inference settings.
COLA_DEVICE=auto
COLA_DEFAULT_MAX_NEW_TOKENS=32
COLA_MAX_NEW_TOKENS_LIMIT=4096
COLA_TIMESTEP_NUM=16
COLA_GUIDANCE_SCALE=7.0
COLA_TOP_K=50
COLA_TOP_P=0.9
COLA_REPETITION_PENALTY=1.1
COLA_PAD_TOKEN_ID=100277
COLA_EOS_TOKEN_ID=100257
COLA_IM_END_TOKEN_ID=100265

# HTTP bind settings used by `python -m openai_adapter.server`.
HOST=0.0.0.0
PORT=8000

